#!/bin/bash

# Check if arguments are provided
if [ $# -eq 0 ]; then
    # Help UI using gum format compliant with AGENTS.md rules (English UI)
    gum format <<EOF
# 🚀 Echotest Help

This is a test script enhanced with **gum** for premium TUI feedback.

### Usage
\`\`\`bash
echotest [arg1] [arg2] ...
\`\`\`

### Examples
- \`echotest "Hello World"\`
- \`echotest --mode debug --verbose\`

> [!TIP]
> Run without any arguments to see this help message.
EOF
    exit 0
fi

# Echo all arguments once with premium styling
# Uses premium lavender (#7A5FFF) double border for output
gum style \
    --foreground "#FFFFFF" \
    --border-foreground "#7A5FFF" \
    --border double \
    --padding "1 3" \
    --margin "1 0" \
    --align center \
    "Output: $*"
